{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {},
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "incremental": true,
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "allowImportingTsExtensions": false,
    "isolatedModules": false,
    "resolvePackageJsonExports": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
